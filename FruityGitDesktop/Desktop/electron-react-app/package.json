{
  "name": "FruityGit",
  "version": "0.1.0",
  "description": "Git VCS for FL Studio",
  "author": "ProstoGarik_",
  "private": true,
  "dependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "electron-is-dev": "^3.0.1",
    "electron-squirrel-startup": "^1.0.1",
    "extract-zip": "^2.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-scripts": "^5.0.1",
    "simple-git": "^3.32.3",
    "web-vitals": "^2.1.4"
  },
  "main": "main.js",
  "homepage": "./",
  "scripts": {
    "start": "electron-forge start",
    "start:react": "react-scripts start",
    "build:python-exe": "py -3.12 -m PyInstaller --onefile --name flp_processor resources/python-app/dist/flp_processor.py --distpath resources/python-app/dist --workpath resources/python-app/build --specpath resources/python-app",
    "build": "react-scripts build",
    "electron": "electron .",
    "free-port": "kill-port 3002",
    "dev": "npm run free-port && concurrently --kill-others \"cross-env BROWSER=none PORT=3002 npm run start:react\" \"wait-on tcp:127.0.0.1:3002 && npm run electron\"",
    "postinstall": "electron-builder install-app-deps",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@electron/rebuild": "^4.0.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^37.0.0",
    "kill-port": "^2.0.1",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.yourname.electronreactapp",
    "productName": "Electron React App",
    "files": [
      "build/**/*",
      "main.js",
      "preload.js"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "resources/python-app/dist",
        "to": "resources/python-app/dist"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.icns"
    }
  }
}
